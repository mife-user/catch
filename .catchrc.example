{
  "default_recursive": false,
  "default_page_size": 10,
  "default_context_lines": 0,
  "default_max_goroutine": 10,
  "default_max_file_size": 10485760,
  "default_max_matches": 100,
  "default_export_format": "json",
  "history_max_entries": 50,
  "skip_dirs": [
    ".git",
    "node_modules",
    "vendor",
    ".vscode",
    ".idea",
    "__pycache__"
  ],
  "skip_extensions": [
    ".exe",
    ".dll",
    ".so",
    ".dylib",
    ".zip",
    ".tar",
    ".gz",
    ".rar",
    ".7z"
  ],
  "theme": "auto"
}
